{
  "name": "TreatmentPlan",
  "type": "object",
  "properties": {
    "client_name": {
      "type": "string",
      "description": "Client's name or initials"
    },
    "big_picture": {
      "type": "string",
      "description": "The overarching goal / big picture"
    },
    "goals": {
      "type": "array",
      "description": "Treatment goals with color coding",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "collapsed": {
            "type": "boolean"
          },
          "objectives": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "done": {
                  "type": "boolean"
                }
              }
            }
          },
          "next_steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "complete"
      ],
      "default": "active"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "client_name"
  ]
}
